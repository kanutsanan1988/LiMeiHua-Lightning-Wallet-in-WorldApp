# LiMeiHua Lightning Wallet in WorldApp - Environment Variables
# 
# ชุดซอฟต์แวร์ชุดนี้ มีไว้เพื่อเป็นโครงสร้างพื้นฐานทางการเงินยุคใหม่
# เพื่อรองรับการไหลของเงินจำนวนมหาศาลของท่านผู้เฒ่าหลี่เหมยฮัว หรือ LiMeiHua Grand Mother
# และ source code นี้สร้างโดย Mr.Kanutsanan Pongpanna (นายคณัสนันท์ พงษ์พันนา)
# URL: https://chatgpt.com/g/g-68d289535dec81919445deb9830f2d8e-kanutsanan-pongpanna

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3000

# World ID Configuration
WORLD_ID_API_URL=https://api.worldcoin.org
WORLD_ID_API_KEY=your_world_id_api_key_here
WORLD_ID_APP_ID=your_world_id_app_id_here

# Lightning Network Configuration
LIGHTNING_RPC_URL=http://localhost:8080
LIGHTNING_MACAROON_PATH=/path/to/admin.macaroon
LIGHTNING_CERT_PATH=/path/to/tls.cert

# Bitcoin Configuration
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin_password

# Taproot Assets Configuration
TAPROOT_ASSETS_API_URL=http://localhost:8089
TAPROOT_ASSETS_API_KEY=your_taproot_assets_api_key

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/limeihua-wallet

# Security
JWT_SECRET=your_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key_here

# Feature Flags
ENABLE_WORLD_ID_VERIFICATION=true
ENABLE_TAPROOT_ASSETS=true
ENABLE_BATCH_OPERATIONS=false

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_URL=https://your-domain.com/webhooks

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=your_analytics_api_key
